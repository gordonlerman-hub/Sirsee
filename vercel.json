{
  "rewrites": [
    { "source": "/api/config", "destination": "/api/index" },
    { "source": "/api/recommendations", "destination": "/api/index" },
    { "source": "/api/reminders", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    },
    "api/cron/reminders.py": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 * * * *"
    }
  ]
}
