# Supabase Auth — required for notification sign-up and login.
# Create a project at https://supabase.com, then copy these from Project Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Google sign-in (optional) — run: python3 scripts/configure_google_auth.py
# Personal access token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
# Google Cloud OAuth web client: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# In Supabase Dashboard → Authentication → Providers:
# - Enable Email provider (for email + password accounts)
# - Enable Google provider and add http://127.0.0.1:4174 to redirect URLs

# Transactional emails (Resend) — https://resend.com
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=Sirsee <onboarding@resend.dev>
APP_URL=https://sirseegift.com

# Service role key (server/cron only — never expose in the browser)
# Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
