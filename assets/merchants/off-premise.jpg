<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <defs>
    <style type="text/css"><![CDATA[
      @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;500&display=swap');
      .wordmark { font-family: 'Outfit', 'Helvetica Neue', 'Avenir', sans-serif; font-weight: 200; fill: #f0ebe3; letter-spacing: 0.06em; }
      .subtitle { font-family: 'Outfit', 'Helvetica Neue', 'Avenir', sans-serif; font-weight: 500; letter-spacing: 0.32em; fill: #c4886b; text-transform: uppercase; }
    ]]></style>
  </defs>

  <!-- Forest green background -->
  <rect width="1200" height="630" fill="#0d3b38"/>

  <!-- Decorative copper border (mirroring the brand wordmark's rectangular frame) -->
  <rect x="60" y="60" width="1080" height="510" fill="none" stroke="#c4886b" stroke-width="1.5" rx="2"/>

  <!-- Wordmark — "OFF PREMISE" -->
  <text x="600" y="318" text-anchor="middle" class="wordmark" font-size="124">OFF PREMISE</text>

  <!-- Copper rule -->
  <line x1="500" y1="378" x2="700" y2="378" stroke="#c4886b" stroke-width="1.5"/>

  <!-- Subtitle -->
  <text x="600" y="424" text-anchor="middle" class="subtitle" font-size="22">LINCOLN PARK · CHICAGO</text>
</svg>
